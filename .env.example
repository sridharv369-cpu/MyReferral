# =========================================================
# MyReferral - Environment Variables Example
# Copy this file to .env.local (Next.js) and fill in values
# NEVER commit .env.local or real secrets to version control
# =========================================================

# ---------------------------------------------------------
# 1. APPLICATION CONFIGURATION
# General app-level metadata used across the codebase
# ---------------------------------------------------------
APP_NAME=MyReferral
APP_VERSION=1.0.0
APP_URL=https://myreferral.example.com
SUPPORT_EMAIL=support@myreferral.example.com

# ---------------------------------------------------------
# 2. ENVIRONMENT
# Controls runtime behavior (development | staging | production)
# ---------------------------------------------------------
NODE_ENV=development
APP_ENV=local

# ---------------------------------------------------------
# 3. NEXT.JS
# Public vars (prefixed NEXT_PUBLIC_) are exposed to the browser
# Non-public vars stay server-side only
# ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=MyReferral
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-32-char-secret

# ---------------------------------------------------------
# 4. SUPABASE
# Core backend/database service configuration
# Public keys are safe for client; service role key is server-only
# ---------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------------------------------------------------------
# 5. AUTHENTICATION
# Google OAuth credentials for Supabase Auth / NextAuth
# ---------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
AUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback/google
AUTH_SESSION_MAX_AGE=604800

# ---------------------------------------------------------
# 6. STORAGE
# Supabase Storage bucket configuration
# ---------------------------------------------------------
SUPABASE_STORAGE_BUCKET=myreferral-assets
SUPABASE_STORAGE_URL=https://your-project-ref.supabase.co/storage/v1
MAX_UPLOAD_SIZE_MB=10

# ---------------------------------------------------------
# 7. DATABASE
# Direct PostgreSQL connection (used for migrations / ORM access)
# ---------------------------------------------------------
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
DATABASE_POOL_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true
DATABASE_SSL=true

# ---------------------------------------------------------
# 8. LOGGING
# Controls application logging verbosity and destinations
# ---------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ---------------------------------------------------------
# 9. SECURITY
# Secrets and policies for hardening the application
# ---------------------------------------------------------
JWT_SECRET=replace-with-random-secret
ENCRYPTION_KEY=replace-with-32-byte-key
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://myreferral.example.com
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ---------------------------------------------------------
# 10. EMAIL (FUTURE)
# Placeholder for transactional email provider integration
# ---------------------------------------------------------
EMAIL_PROVIDER=resend
EMAIL_API_KEY=your-email-provider-api-key
EMAIL_FROM_ADDRESS=no-reply@myreferral.example.com
EMAIL_FROM_NAME=MyReferral

# ---------------------------------------------------------
# 11. ANALYTICS (FUTURE)
# Placeholder for product/usage analytics integration
# ---------------------------------------------------------
NEXT_PUBLIC_ANALYTICS_ID=your-analytics-tracking-id
ANALYTICS_WRITE_KEY=your-analytics-write-key
ENABLE_ANALYTICS=false

# ---------------------------------------------------------
# 12. AI CONFIGURATION (FUTURE)
# Placeholder for AI-powered features (e.g., referral matching)
# ---------------------------------------------------------
AI_PROVIDER=anthropic
AI_API_KEY=your-ai-provider-api-key
AI_MODEL=claude-sonnet-5
ENABLE_AI_FEATURES=false
