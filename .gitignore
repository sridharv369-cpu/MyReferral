# ==========================================================================
# MyReferral - .gitignore
# Next.js / React / TypeScript / Node.js / Supabase / PostgreSQL / Vercel
# ==========================================================================

# ---------------------------------------------------------------------
# Dependencies / Node Modules
# ---------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
jspm_packages/

# ---------------------------------------------------------------------
# Build Output
# ---------------------------------------------------------------------
/build
/dist
/out
/.output
/.vercel/output

# ---------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------
.next/
next-env.d.ts
.swc/

# ---------------------------------------------------------------------
# Vercel
# ---------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------
# Environment Variables
# ---------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ---------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------
/coverage
*.lcov
.nyc_output
/cypress/videos/
/cypress/screenshots/
/playwright-report/
/test-results/

# ---------------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------------
*.tsbuildinfo
.tsc-out/

# ---------------------------------------------------------------------
# Supabase (local dev)
# ---------------------------------------------------------------------
.supabase/
supabase/.branches
supabase/.temp
supabase/.env

# ---------------------------------------------------------------------
# PostgreSQL / Database Dumps
# ---------------------------------------------------------------------
*.sql.bak
*.dump
*.pgdata/

# ---------------------------------------------------------------------
# Docker (temporary/local)
# ---------------------------------------------------------------------
docker-compose.override.yml
.docker/
*.pid

# ---------------------------------------------------------------------
# Terraform (future infra-as-code)
# ---------------------------------------------------------------------
*.tfstate
*.tfstate.*
*.tfvars
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# ---------------------------------------------------------------------
# VS Code
# ---------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace

# ---------------------------------------------------------------------
# OS Generated Files
# ---------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------
# Temporary / Cache Files
# ---------------------------------------------------------------------
*.tmp
*.temp
.cache/
.eslintcache
.turbo/
*.bak
*.swp
*.swo

# ---------------------------------------------------------------------
# Package Manager Locks (optional - uncomment if not tracking)
# ---------------------------------------------------------------------
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
